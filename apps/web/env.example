# ============================================
# GiPos Web Application - Environment Variables
# ============================================
# Copy this file to .env.local and update the values
# cp env.example .env.local
#
# Note: Next.js automatically loads .env.local in development
# For production, set these as environment variables in your hosting platform

# ============================================
# API Configuration
# ============================================
# Base URL for the backend API
# Development: http://localhost:8080
# Production: https://api.gipos.id
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# API Base Path
# Base path for API endpoints (e.g., /api/v1, /api/v2)
# Default: /api/v1
# Change this if your API uses a different versioning scheme
# Leave empty if backend does not use a base path
NEXT_PUBLIC_API_BASE_PATH=/api/v1

# ============================================
# Storage Configuration
# ============================================
# Note: Storage (R2 Cloudflare) is configured on the backend
# The frontend will use the upload API endpoint (/api/v1/upload/image)
# which handles R2 Cloudflare storage automatically
# No frontend configuration needed for storage

# ============================================
# Authentication Configuration
# ============================================
# NextAuth Secret (required for NextAuth.js)
# Generate a random secret using:
#   openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
# IMPORTANT: Use a strong, random secret in production!
AUTH_SECRET=your-secret-key-change-in-production

# ============================================
# Application Configuration
# ============================================
# Node Environment
# Options: development, production, test
# Next.js automatically sets this, but you can override if needed
NODE_ENV=development

# ============================================
# Notes
# ============================================
# 1. Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# 2. Never commit .env.local file to version control
# 3. Use strong, random AUTH_SECRET in production
# 4. Update NEXT_PUBLIC_API_BASE_URL for production
# 5. For Vercel deployment, set these in Vercel dashboard:
#    - Settings > Environment Variables
# 6. For other platforms, set as environment variables in your hosting config
