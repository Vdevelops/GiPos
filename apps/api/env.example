# ============================================
# GiPos API - Environment Variables
# ============================================
# Copy this file to .env and update the values
# cp env.example .env

# ============================================
# Application Configuration
# ============================================
# Application name
APP_NAME=GiPos API

# Application environment
# Options: development, production, staging
APP_ENV=development

# Application version
APP_VERSION=1.0.0

# Server host (0.0.0.0 for all interfaces, localhost for local only)
APP_HOST=0.0.0.0

# Server port
APP_PORT=8080

# Server read timeout (e.g., 15s, 30s, 1m)
SERVER_READ_TIMEOUT=15s

# Server write timeout (e.g., 15s, 30s, 1m)
SERVER_WRITE_TIMEOUT=15s

# Timezone (e.g., Asia/Jakarta, UTC)
TZ=Asia/Jakarta

# ============================================
# Database Configuration
# ============================================
# PostgreSQL database host
DB_HOST=localhost

# PostgreSQL database port
DB_PORT=5432

# Database user
DB_USER=gipos

# Database password
DB_PASSWORD=gipos_password

# Database name
DB_NAME=gipos_db

# SSL mode (disable, require, verify-ca, verify-full)
DB_SSLMODE=disable

# Database timezone
DB_TIMEZONE=Asia/Jakarta

# ============================================
# Redis Configuration
# ============================================
# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis password (leave empty if no password)
REDIS_PASSWORD=

# Redis database number (0-15)
REDIS_DB=0

# ============================================
# JWT Configuration
# ============================================
# JWT secret key (REQUIRED - use strong random secret in production!)
# Generate a random secret using:
#   openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
JWT_SECRET=your-secret-key-change-in-production

# JWT access token expiry (e.g., 15m, 1h, 24h, 1d)
JWT_ACCESS_TOKEN_EXPIRY=15h

# JWT refresh token expiry (e.g., 24h, 7d, 30d)
JWT_REFRESH_TOKEN_EXPIRY=15h

# ============================================
# CORS Configuration
# ============================================
# Allowed origins (comma-separated)
# Development: http://localhost:3000,http://localhost:3001
# Staging/production: add your frontend origin here, for example:
#   https://warungwanamukti.my.id,https://www.warungwanamukti.my.id
# If you test from Vercel preview URLs, you can add:
#   https://*.vercel.app
# For tablet/phone testing in the same LAN, you can use wildcard origins:
#   http://192.168.*:3000,http://10.*.*.*:3000,http://172.16.*.*:3000
# Wildcard (*) is supported by middleware.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://warungwanamukti.my.id,https://www.warungwanamukti.my.id,https://*.vercel.app

# Allowed HTTP methods (comma-separated)
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Allowed headers (comma-separated)
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Locale,X-Request-ID

# ============================================
# Rate Limiting Configuration
# ============================================
# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Maximum requests per window
RATE_LIMIT_REQUESTS=100

# Rate limit window (e.g., 1m, 5m, 15m)
RATE_LIMIT_WINDOW=1m

# ============================================
# File Upload Configuration
# ============================================
# Maximum upload size in bytes (default: 10485760 = 10MB)
MAX_UPLOAD_SIZE=10485760

# Upload directory path
UPLOAD_PATH=./uploads

# ============================================
# Storage Configuration
# ============================================
# Storage type: local, r2
STORAGE_TYPE=r2

# Cloudflare R2 Configuration
# Get your R2 credentials from: https://dash.cloudflare.com/
# R2 endpoint URL (format: https://<account-id>.r2.cloudflarestorage.com)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# R2 Access Key ID
R2_ACCESS_KEY_ID=your-access-key-id

# R2 Secret Access Key
R2_SECRET_ACCESS_KEY=your-secret-access-key

# R2 Bucket name
R2_BUCKET=

# R2 Public URL (CDN URL for accessing uploaded files)
# Format: https://cdn.yourdomain.com or https://<bucket-name>.<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Storage base path (folder prefix in bucket)
STORAGE_BASE_URL=uploads

# ============================================
# External Integrations
# ============================================
# Xendit API Key (for QRIS and E-wallet payments)
# Get your API key from: https://dashboard.xendit.co/settings/developers#api-keys
# For development, use test API key
# For production, use live API key
XENDIT_API_KEY=your-xendit-api-key-here

# ============================================
# Development/Testing Options
# ============================================
# Skip auto migration on startup (1 = skip, 0 = run migrations)
SKIP_AUTO_MIGRATE=0

# Drop tables on migrate (WARNING: This will delete all data!)
# Only use in development: DROP_TABLES_ON_MIGRATE=1
# NEVER use in production!
# DROP_TABLES_ON_MIGRATE=0

# Auto seed database on startup (true/false)
AUTO_SEED=false

# Skip auto seed on startup (1 = skip, 0 = allow by APP_ENV/AUTO_SEED rules)
SKIP_AUTO_SEED=0

# ============================================
# Notes
# ============================================
# 1. Never commit .env file to version control
# 2. Use strong, random secrets in production
# 3. Update CORS_ALLOWED_ORIGINS for production
# 4. Use SSL for database connections in production (DB_SSLMODE=require)
# 5. Set APP_ENV=production in production environment