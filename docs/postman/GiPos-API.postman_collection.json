							"path": ["api", "v1", "sales", ":id"],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						},
						"description": "Get sale detail by ID."
					},
					"response": []
				},
				{
					"name": "Void Sale",
