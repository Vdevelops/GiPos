								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/sales/:id/void",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sales", ":id", "void"],
							"variable": [
								{
									"key": "id",
									"value": "1"
								}
							]
						},
						"description": "Void a sale (before payment). Restores stock if product tracks stock."
					},
					"response": []
				}
			],
			"description": "Sales transaction endpoints."
		},
